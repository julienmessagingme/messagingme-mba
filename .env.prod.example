# .env.prod — à créer SUR LE VPS (jamais commité). Chargé par mba-api et mba-worker.

NODE_ENV=production
PORT=8095

# Auth : OBLIGATOIRE en prod (>= 32 octets). Sans lui, le boot échoue.
#   openssl rand -base64 48
AUTH_SECRET=

# Surface d'exploitation cross-tenant /ops (lecture seule). Vide -> /ops désactivé (401).
# Si défini, DOIT faire >= 32 octets aléatoires : openssl rand -base64 48
OPS_TOKEN=

# Base Supabase. ATTENTION : le host DIRECT db.<ref>.supabase.co est IPv6-only et injoignable
# depuis un conteneur Docker sur le VPS. Utiliser le POOLER (IPv4) :
#   postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# (port 5432 = session mode, requis par pg-boss ; PAS 6543 transaction mode).
DATABASE_URL=
# ⚠️ Corrigé le 2026-07-18. Ce commentaire affirmait que le pooler AWS a un certificat public et invitait à
# « retirer cette ligne une fois sur le pooler ». C'est FAUX, et le suivre CASSE la production : la chaîne du
# pooler Supabase est auto-signée, la vérification complète échoue (constaté, cf. todo.md).
# En l'état, DB_SSL_INSECURE=true chiffre mais NE VÉRIFIE PAS le certificat : aucune protection MITM sur un
# trafic qui transporte tokens Meta, tokens HubSpot déchiffrés, numéros et contenus de conversations.
# Le vrai correctif n'est PAS de retirer cette ligne : télécharger la CA Supabase, la monter dans le conteneur,
# poser DB_SSL_CA_FILE, PUIS retirer DB_SSL_INSECURE. Bloc 4 du PLAN.md.
DB_SSL_INSECURE=true
# Budget de connexions (pooler Supabase en session mode, ~15 clients, PARTAGÉ avec mm-hubspot).
# Laisser vide = défauts bornés du code (3 / 2 / 8000). Ne PAS remonter sans lire src/config.ts.
DB_POOL_MAX=
PGBOSS_MAX=
DB_CONN_TIMEOUT_MS=
PGBOSS_SCHEMA=pgboss

# Démo : le worker n'appelle pas Meta et marque les envois 'sent'. Passer à false pour le live.
DRY_RUN=true

# Meta (pour le live, DRY_RUN=false) :
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v25.0
META_APP_SECRET=
META_VERIFY_TOKEN=

DEFAULT_COUNTRY=FR

# Support (formulaire de contact -> email via Resend, phase 7)
RESEND_API_KEY=
SUPPORT_FROM=onboarding@resend.dev
SUPPORT_TO=
