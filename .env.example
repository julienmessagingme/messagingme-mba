# Serveur
PORT=8095

# Meta (webhooks)
META_APP_SECRET=            # secret de l'app Meta, pour valider X-Hub-Signature-256
META_VERIFY_TOKEN=          # token du handshake de vérification du webhook
META_ACCESS_TOKEN=         # token d'envoi outbound (worker campaign-run)

# Auth console : OBLIGATOIRE en production (>= 32 octets aléatoires). Sans lui, le boot
# échoue en prod. Générer avec : openssl rand -base64 48
AUTH_SECRET=

# Base de données (Postgres local en dev/test, Supabase en prod)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mba
# TLS Postgres (sécurisé par défaut = vérif du certificat) :
#   DB_SSL_CA_FILE=/chemin/vers/supabase-ca.crt   -> vérif COMPLÈTE (cible prod)
#   DB_SSL_INSECURE=true                            -> pas de vérif (fallback dev, endpoint direct Supabase)
