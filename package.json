{
  "name": "messagingme-mba",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "worker": "tsx src/worker.ts",
    "migrate": "tsx db/migrate.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.25.1",
    "secure-json-parse": "^4.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
